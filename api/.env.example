# --- Fournisseur par défaut pour POST /api/chat ---
LLM_PROVIDER=anthropic
# Valeurs : anthropic | openai | ollama | gemini
# Tu peux aussi envoyer "provider" dans le JSON pour un seul appel.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI (API plateforme) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  # vide = défaut ; sinon proxy / Azure OpenAI

# --- Ollama (API compatible OpenAI, en local) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3.2
# OLLAMA_API_KEY=ollama

# --- Google Gemini (clé = Google AI Studio, pas l’abonnement Gemini Pro “grand public”) ---
# L’offre Gemini Pro / Google One AI Premium est surtout pour l’app consommateur.
# Pour l’API, crée une clé sur https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# ou : GEMINI_API_KEY=  (même valeur que dans Google AI Studio)
# Si erreur 429 / quota : autre modèle ou facturation Google Cloud ; ex. gemini-2.5-flash-lite, gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# --- HTTP ---
MAX_OUTPUT_TOKENS=4096

# --- RAG (rapports dans data/reports/ ; puis POST /api/rag/reindex ou python -m rag.ingest) ---
# RAG_REPORTS_DIR=data/reports
# RAG_CHROMA_DIR=chroma_db
# RAG_CHUNK_SIZE=1200
# RAG_CHUNK_OVERLAP=200
# RAG_TOP_K=5
# RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
# POST /api/chat : "use_rag": true → retrieve sur la dernière question user + injection system

# CORS : origines du *frontend* telles qu’affichées dans la barre d’adresse du navigateur
# (ex. http://localhost:5173 pour Vite, http://localhost:3000 pour Create React App).
# Ce n’est PAS l’URL du serveur FastAPI (souvent http://127.0.0.1:8000).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
